{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "ecrc",
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "**/node_modules/**",
      "serve.mjs",
      "screenshot.mjs",
      "package.json",
      "package-lock.json",
      "CLAUDE.md",
      "workflows/**",
      "tools/**",
      "components/**",
      "temporary screenshots/**",
      ".claude/**"
    ],
    "rewrites": [
      { "source": "/admin", "destination": "/admin.html" },
      { "source": "/login", "destination": "/login.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|mjs)",
        "headers": [{ "key": "Cache-Control", "value": "max-age=3600" }]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|gif|svg|webp)",
        "headers": [{ "key": "Cache-Control", "value": "max-age=86400" }]
      }
    ]
  }
}
